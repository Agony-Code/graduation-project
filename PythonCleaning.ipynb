import pandas as pd
import numpy as np

df = pd.read_csv('railway.csv')
df.columns = [col.replace(' ', '_') for col in df.columns]

df['Railcard'] = df['Railcard'].fillna('None')
df['Reason_for_Delay'] = df['Reason_for_Delay'].fillna('No Delay')

delay_map = {
    'Signal failure':     'Signal Failure',
    'Weather Conditions': 'Weather',
    'Staff Shortage':     'Staffing',
}
df['Reason_for_Delay'] = df['Reason_for_Delay'].replace(delay_map)

same_time_mask = (
    (df['Arrival_Time'] == df['Actual_Arrival_Time']) &
    (df['Journey_Status'] == 'Delayed')
)
df.loc[same_time_mask, 'Journey_Status']   = 'On Time'
df.loc[same_time_mask, 'Reason_for_Delay'] = 'No Delay'
df.loc[same_time_mask, 'Refund_Request']   = 'No'

advance_delayed_mask = (
    (df['Ticket_Type'] == 'Advance') &
    (df['Journey_Status'] == 'Delayed')
)
df.loc[advance_delayed_mask, 'Refund_Request'] = 'Non_Refundable'

DateConvP = pd.to_datetime(df['Date_of_Purchase'], format='%m/%d/%Y')
DateConvJ = pd.to_datetime(df['Date_of_Journey'],  format='%m/%d/%Y')

date_str  = DateConvJ.dt.strftime('%Y-%m-%d')
dept      = pd.to_datetime(date_str + ' ' + df['Departure_Time'])
sched_arr = pd.to_datetime(date_str + ' ' + df['Arrival_Time'])
act_arr   = pd.to_datetime(date_str + ' ' + df['Actual_Arrival_Time'], errors='coerce')

sched_arr[sched_arr < dept] += pd.Timedelta(days=1)
act_arr[(act_arr.notnull()) & (act_arr < dept)] += pd.Timedelta(days=1)

df['Delay_Minutes'] = (act_arr - sched_arr).dt.total_seconds() / 60
df.loc[df['Journey_Status'] == 'On Time',   'Delay_Minutes'] = 0
df.loc[df['Journey_Status'] == 'Cancelled', 'Delay_Minutes'] = np.nan

df['Journey_Duration_Minutes'] = (sched_arr - dept).dt.total_seconds() / 60

def calc_refund(row):
    if row['Journey_Status'] == 'Cancelled' and row['Refund_Request'] == 'Yes':
        return row['Price']                        
    if row['Ticket_Type'] == 'Advance':
        return 0                                 
    if row['Journey_Status'] == 'Delayed' and row['Refund_Request'] == 'Yes':
        mins = row['Delay_Minutes']
        if mins >= 60:   return row['Price']      
        elif mins >= 30: return row['Price'] * 0.50  
        elif mins >= 15: return row['Price'] * 0.25  
        else:            return 0                  
    return 0

df['Refunded_Amount'] = df.apply(calc_refund, axis=1)

df['Month_of_Purchase'] = DateConvP.dt.month_name()
df['Purchase_Hour']     = pd.to_datetime(df['Time_of_Purchase'], format='%H:%M:%S').dt.hour
df['Departure_Hour']    = pd.to_datetime(df['Departure_Time'],   format='%H:%M:%S').dt.hour
df['Departure_Day']     = DateConvJ.dt.day_name()

peak_mask = (
    ((df['Departure_Hour'] >= 6)  & (df['Departure_Hour'] < 8)) |
    ((df['Departure_Hour'] >= 16) & (df['Departure_Hour'] < 18))
)
df['OffPeak_Violation'] = ((df['Ticket_Type'] == 'Off-Peak') & peak_mask).astype(int)

df['Date_of_Purchase'] = DateConvP.dt.date
df['Date_of_Journey']  = DateConvJ.dt.date

df.to_excel('railway_cleanedPython.xlsx', index=False)