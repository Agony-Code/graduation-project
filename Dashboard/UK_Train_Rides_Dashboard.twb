    <worksheet name='Transactions by Hour of Day'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#499894' fontsize='10'>&lt;Sheet Name&gt;</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Routes+ (Wameed_FinalSQL_Model) (2)' name='federated.0pl2ns61x0z9eo13do72b03wi55l (copy)' />
          </datasources>
          <datasource-dependencies datasource='federated.0pl2ns61x0z9eo13do72b03wi55l (copy)'>
            <column caption='Hour_Sort' datatype='integer' name='[Calculation_2041585046654978]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='DATEPART(&apos;hour&apos;, DATETIME([Purchase_Time]))' />
            </column>
            <column caption='Purchase_Hour' datatype='string' name='[Calculation_2041585046814723]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF DATEPART(&apos;hour&apos;, DATETIME([Purchase_Time])) = 0 THEN &quot;12 AM&quot;&#13;&#10;ELSEIF DATEPART(&apos;hour&apos;, DATETIME([Purchase_Time])) &lt; 12 THEN STR(DATEPART(&apos;hour&apos;, DATETIME([Purchase_Time]))) + &quot; AM&quot;&#13;&#10;ELSEIF DATEPART(&apos;hour&apos;, DATETIME([Purchase_Time])) = 12 THEN &quot;12 PM&quot;&#13;&#10;ELSE STR(DATEPART(&apos;hour&apos;, DATETIME([Purchase_Time])) - 12) + &quot; PM&quot;&#13;&#10;END' />
            </column>
            <column caption='Purchase Date' datatype='date' name='[Purchase_Date]' role='dimension' type='ordinal' />
            <column caption='Purchase Time' datatype='string' name='[Purchase_Time]' role='dimension' type='nominal' />
            <column caption='Transactions' datatype='table' name='[__tableau_internal_object_id__].[Transactions_F8346F5A74E64D93A3C5352504665F97]' role='measure' type='quantitative' />
            <column-instance column='[__tableau_internal_object_id__].[Transactions_F8346F5A74E64D93A3C5352504665F97]' derivation='Count' name='[__tableau_internal_object_id__].[cnt:Transactions_F8346F5A74E64D93A3C5352504665F97:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_2041585046654978]' derivation='Min' name='[min:Calculation_2041585046654978:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Purchase_Date]' derivation='MY' name='[my:Purchase_Date:ok]' pivot='key' type='ordinal' />
            <column-instance column='[Calculation_2041585046814723]' derivation='None' name='[none:Calculation_2041585046814723:nk]' pivot='key' type='nominal' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.0pl2ns61x0z9eo13do72b03wi55l (copy)].[my:Purchase_Date:ok]' filter-group='5'>
            <groupfilter function='level-members' level='[my:Purchase_Date:ok]' user:ui-enumeration='all' user:ui-marker='enumerate' />
          </filter>
          <computed-sort column='[federated.0pl2ns61x0z9eo13do72b03wi55l (copy)].[none:Calculation_2041585046814723:nk]' direction='ASC' using='[federated.0pl2ns61x0z9eo13do72b03wi55l (copy)].[min:Calculation_2041585046654978:qk]' />
          <slices>
            <column>[federated.0pl2ns61x0z9eo13do72b03wi55l (copy)].[my:Purchase_Date:ok]</column>
          </slices>
          <aggregation value='true' />
        </view>
