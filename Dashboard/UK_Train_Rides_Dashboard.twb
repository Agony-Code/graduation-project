            <column caption='Delay_Phase' datatype='string' name='[Calculation_0965164481204229]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Delay_Minutes] &gt;= 0 AND [Delay_Minutes] &lt;= 14 THEN &apos;0-15 min&apos;&#13;&#10;&#13;&#10;ELSEIF [Delay_Minutes] &gt;= 15 AND [Delay_Minutes] &lt;= 29 THEN &apos;15-30 min&apos;&#13;&#10;&#13;&#10;ELSEIF [Delay_Minutes] &gt;= 30 AND [Delay_Minutes] &lt;= 59 THEN &apos;30-60 min&apos;&#13;&#10;&#13;&#10;ELSE &apos;60+ min&apos;&#13;&#10;END' />
            </column>
            <column caption='Delay Minutes' datatype='integer' name='[Delay_Minutes]' role='measure' type='quantitative' />
            <column caption='Refunded Amount (Transactions1)' datatype='real' name='[Refunded_Amount (Transactions1)]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_0965164481204229]' derivation='None' name='[none:Calculation_0965164481204229:nk]' pivot='key' type='nominal' />
            <column-instance column='[Refunded_Amount (Transactions1)]' derivation='Sum' name='[sum:Refunded_Amount (Transactions1):qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
