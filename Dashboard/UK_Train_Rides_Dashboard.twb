      <column caption='OnTime_Count' datatype='integer' name='[Calculation_0461587203624961]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Trip_Status] = &quot;On Time&quot; THEN 1 ELSE 0 END)' />
      </column>
      <column caption='Delay_Rate' datatype='real' name='[Calculation_0461587203948546]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM(IF [Trip_Status] = &quot;Delayed&quot; THEN 1 ELSE 0 END) * 100.0)&#13;&#10;/ COUNTD([Trip_ID])' />
      </column>
      <column caption='Delay_Count' datatype='integer' name='[Calculation_0461587204534275]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Trip_Status] = &quot;Delayed&quot; THEN 1 ELSE 0 END)' />
      </column>
      <column caption='Cancellation_Rate' datatype='real' name='[Calculation_0461587205095428]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM(IF [Trip_Status] = &quot;Cancelled&quot; THEN 1 ELSE 0 END) * 100.0)&#13;&#10;/ COUNTD([Trip_ID])' />
      </column>
      <column caption='Cancelled_Count' datatype='integer' name='[Calculation_0461587205861381]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Trip_Status] = &quot;Cancelled&quot; THEN 1 ELSE 0 END)' />
      </column>
      <column caption='Week_Trip_Count' datatype='string' name='[Calculation_0461587208843270]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF DATENAME(&apos;weekday&apos;, DATE([Trip_Date])) IN &#13;&#10;(&quot;Monday&quot;,&quot;Tuesday&quot;,&quot;Wednesday&quot;,&quot;Thursday&quot;,&quot;Friday&quot;)&#13;&#10;THEN &quot;Weekdays&quot;&#13;&#10;ELSE &quot;Weekends&quot;&#13;&#10;END' />
      </column>
      <column caption='Zero_Axis' datatype='integer' name='[Calculation_0461587211137031]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='0' />
      </column>
      <column caption='TimesOfDay_Trips' datatype='string' name='[Calculation_0461587212509192]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF DATEPART(&apos;hour&apos;, DATETIME([Departure_Time])) &gt;= 5 &#13;&#10;AND DATEPART(&apos;hour&apos;, DATETIME([Departure_Time])) &lt;= 11 THEN &quot;Morning&quot;&#13;&#10;&#13;&#10;ELSEIF DATEPART(&apos;hour&apos;, DATETIME([Departure_Time])) &gt;= 12 &#13;&#10;AND DATEPART(&apos;hour&apos;, DATETIME([Departure_Time])) &lt;= 16 THEN &quot;Afternoon&quot;&#13;&#10;&#13;&#10;ELSEIF DATEPART(&apos;hour&apos;, DATETIME([Departure_Time])) &gt;= 17 &#13;&#10;AND DATEPART(&apos;hour&apos;, DATETIME([Departure_Time])) &lt;= 20 THEN &quot;Evening&quot;&#13;&#10;&#13;&#10;ELSE &quot;Night&quot;&#13;&#10;END' />
      </column>
      <column caption='Rounded_Box' datatype='string' name='[Calculation_0552846593847296]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;&quot;' />
      </column>
      <column caption='AVG_Trips_Duration' datatype='real' name='[Calculation_0567415779348480]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Trip_Duration])' />
      </column>
      <column caption='Refund_Rate2' datatype='real' name='[Calculation_0954718864998400]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM(IF [Refunded_Amount] &gt; 0 THEN 1 ELSE 0 END)&#13;&#10;* 100.0) / COUNTD([Transaction_ID])' />
      </column>
      <column caption='Refunded_Tickets' datatype='integer' name='[Calculation_0954718866415617]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Refunded_Amount] &gt; 0 THEN 1 ELSE 0 END)' />
      </column>
      <column caption='AVG_Delay' datatype='real' name='[Calculation_0965164472438784]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Delay_Minutes])' />
      </column>
      <column caption='Longest_Delay' datatype='integer' name='[Calculation_0965164472844289]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MAX([Delay_Minutes])' />
      </column>
      <column caption='Delayed_Trips' datatype='integer' name='[Calculation_0965164474396675]' role='measure' type='ordinal'>
        <calculation class='tableau' formula='COUNT(IF [Trip_Status] = &quot;Delayed&quot; THEN [Trip_Status] END)' />
      </column>
      <column caption='Delay_Phase' datatype='string' name='[Calculation_0965164481204229]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Delay_Minutes] &gt;= 0 AND [Delay_Minutes] &lt;= 14 THEN &apos;0-15 min&apos;&#13;&#10;&#13;&#10;ELSEIF [Delay_Minutes] &gt;= 15 AND [Delay_Minutes] &lt;= 29 THEN &apos;15-30 min&apos;&#13;&#10;&#13;&#10;ELSEIF [Delay_Minutes] &gt;= 30 AND [Delay_Minutes] &lt;= 59 THEN &apos;30-60 min&apos;&#13;&#10;&#13;&#10;ELSE &apos;60+ min&apos;&#13;&#10;END' />
      </column>
      <column caption='Discount_Rate' datatype='real' name='[Calculation_1262582093733888]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([Discount_Amount]) * 100.0) / SUM([Original_Price])' />
      </column>
      <column caption='Refunds_Rate' datatype='real' name='[Calculation_1262582103621634]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM(IF [Refunded_Amount] &gt; 0 THEN [Refunded_Amount] END)&#13;&#10;* 100.0) / SUM([Final_Price])' />
