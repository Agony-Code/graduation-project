            <column-instance column='[Calculation_0461587212509192]' derivation='None' name='[none:Calculation_0461587212509192:nk]' pivot='key' type='nominal' />
            <column-instance column='[Trip_Status]' derivation='None' name='[none:Trip_Status:nk]' pivot='key' type='nominal' />
            <column-instance column='[Delay_Minutes]' derivation='Sum' name='[sum:Delay_Minutes:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.0pl2ns61x0z9eo13do72b03wi55l].[none:Trip_Status:nk]'>
            <groupfilter function='member' level='[none:Trip_Status:nk]' member='&quot;Delayed&quot;' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate' />
