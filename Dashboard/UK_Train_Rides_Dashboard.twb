    <worksheet name='Delay Frequency By Time Of Day'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#499894' fontsize='10'>&lt;Sheet Name&gt;</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Routes+ (Wameed_FinalSQL_Model)' name='federated.0pl2ns61x0z9eo13do72b03wi55l' />
          </datasources>
          <datasource-dependencies datasource='federated.0pl2ns61x0z9eo13do72b03wi55l'>
            <column caption='TimesOfDay_Trips' datatype='string' name='[Calculation_0461587212509192]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF DATEPART(&apos;hour&apos;, DATETIME([Departure_Time])) &gt;= 5 &#13;&#10;AND DATEPART(&apos;hour&apos;, DATETIME([Departure_Time])) &lt;= 11 THEN &quot;Morning&quot;&#13;&#10;&#13;&#10;ELSEIF DATEPART(&apos;hour&apos;, DATETIME([Departure_Time])) &gt;= 12 &#13;&#10;AND DATEPART(&apos;hour&apos;, DATETIME([Departure_Time])) &lt;= 16 THEN &quot;Afternoon&quot;&#13;&#10;&#13;&#10;ELSEIF DATEPART(&apos;hour&apos;, DATETIME([Departure_Time])) &gt;= 17 &#13;&#10;AND DATEPART(&apos;hour&apos;, DATETIME([Departure_Time])) &lt;= 20 THEN &quot;Evening&quot;&#13;&#10;&#13;&#10;ELSE &quot;Night&quot;&#13;&#10;END' />
            </column>
            <column caption='Delay Minutes' datatype='integer' name='[Delay_Minutes]' role='measure' type='quantitative' />
            <column caption='Departure Time' datatype='string' name='[Departure_Time]' role='dimension' type='nominal' />
            <column caption='Trip Status' datatype='string' name='[Trip_Status]' role='dimension' type='nominal' />
            <column caption='Trips' datatype='table' name='[__tableau_internal_object_id__].[Trips_AE2AFAD138FE4280B30E9DF25D25B69B]' role='measure' type='quantitative' />
